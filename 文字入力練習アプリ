        { text: "ほし", romaji: "hoshi" }, { text: "うみ", romaji: "umi" }, { text: "やま", romaji: "yama" }, { text: "かわ", romaji: "kawa" }, { text: "もり", romaji: "mori" },
        { text: "き", romaji: "ki" }, { text: "はな", romaji: "hana" }, { text: "くさ", romaji: "kusa" }, { text: "そら", romaji: "sora" }, { text: "ちきゅう", romaji: "chikyuu" },
        { text: "あか", romaji: "aka" }, { text: "あお", romaji: "ao" }, { text: "きいろ", romaji: "kiiro" }, { text: "みどり", romaji: "midori" }, { text: "くろ", romaji: "kuro" },
        { text: "しろ", romaji: "shiro" }, { text: "むらさき", romaji: "murasaki" }, { text: "おれんじ", romaji: "orenji" }, { text: "ぴんく", romaji: "pinku" }, { text: "ちゃいろ", romaji: "chairo" },
        { text: "あたま", romaji: "atama" }, { text: "かお", romaji: "kao" }, { text: "め", romaji: "me" }, { text: "はな", romaji: "hana" }, { text: "くち", romaji: "kuchi" },
        { text: "みみ", romaji: "mimi" }, { text: "て", romaji: "te" }, { text: "あし", romaji: "ashi" }, { text: "ゆび", romaji: "yubi" }, { text: "からだ", romaji: "karada" },
        { text: "こころ", romaji: "kokoro" }, { text: "いのち", romaji: "inochi" }, { text: "なみだ", romaji: "namida" }, { text: "えがお", romaji: "egao" }, { text: "こえ", romaji: "koe" },
        { text: "いえ", romaji: "ie" }, { text: "へや", romaji: "heya" }, { text: "まど", romaji: "mado" }, { text: "どあ", romaji: "doa" }, { text: "かべ", romaji: "kabe" },
        { text: "ゆか", romaji: "yuka" }, { text: "てんじょう", romaji: "tenjou" }, { text: "つくえ", romaji: "tsukue" }, { text: "いす", romaji: "isu" }, { text: "べっど", romaji: "beddo" },
        { text: "とけい", romaji: "tokei" }, { text: "かがみ", romaji: "kagami" }, { text: "ほんだな", romaji: "hondana" }, { text: "てれび", romaji: "terebi" }, { text: "れいぞうこ", romaji: "reizouko" },
        { text: "くるま", romaji: "kuruma" }, { text: "じてんしゃ", romaji: "jitensha" }, { text: "でんしゃ", romaji: "densha" }, { text: "ひこうき", romaji: "hikouki" }, { text: "ふね", romaji: "fune" },
        { text: "ばす", romaji: "basu" }, { text: "しんかんせん", romaji: "shinkansen" }, { text: "たくしー", romaji: "takushi-" }, { text: "えき", romaji: "eki" }, { text: "みち", romaji: "michi" },
        { text: "がっこう", romaji: "gakkou" }, { text: "かいしゃ", romaji: "kaisha" }, { text: "びょういん", romaji: "byouin" }, { text: "こうえん", romaji: "kouen" }, { text: "としょかん", romaji: "toshokan" },
        { text: "ほん", romaji: "hon" }, { text: "えんぴつ", romaji: "enpitsu" }, { text: "けしごむ", romaji: "keshigomu" }, { text: "かばん", romaji: "kaban" }, { text: "くつ", romaji: "kutsu" },
        { text: "ふく", romaji: "fuku" }, { text: "ぼうし", romaji: "boushi" }, { text: "めがね", romaji: "megane" }, { text: "かさ", romaji: "kasa" }, { text: "とけい", romaji: "tokei" },
        { text: "おかね", romaji: "okane" }, { text: "さいふ", romaji: "saifu" }, { text: "かぎ", romaji: "kagi" }, { text: "でんわ", romaji: "denwa" }, { text: "すまほ", romaji: "sumaho" },
        { text: "ぱそこん", romaji: "pasokon" }, { text: "きーぼーど", romaji: "ki-bo-do" }, { text: "まうす", romaji: "mausu" }, { text: "がめん", romaji: "gamen" }, { text: "いんたーねっと", romaji: "inta-netto" },
        { text: "たいぴんぐ", romaji: "taipingu" }, { text: "ぷろぐらみんぐ", romaji: "puroguramingu" }, { text: "えこうでぃんぐ", romaji: "ko-dingu" }, { text: "えらー", romaji: "era-" }, { text: "ばぐ", romaji: "bagu" },
        { text: "あるく", romaji: "aruku" }, { text: "はしる", romaji: "hashiru" }, { text: "とぶ", romaji: "tobu" }, { text: "およぐ", romaji: "oyogu" }, { text: "ねる", romaji: "neru" },
        { text: "おきる", romaji: "okiru" }, { text: "たべる", romaji: "taberu" }, { text: "のむ", romaji: "nomu" }, { text: "みる", romaji: "miru" }, { text: "きく", romaji: "kiku" },
        { text: "はなす", romaji: "hanasu" }, { text: "かく", romaji: "kaku" }, { text: "よむ", romaji: "yomu" }, { text: "あそぶ", romaji: "asobu" }, { text: "はたらく", romaji: "hataraku" },
        { text: "おおきい", romaji: "ookii" }, { text: "ちいさい", romaji: "chiisai" }, { text: "たかい", romaji: "takai" }, { text: "ひくい", romaji: "hikui" }, { text: "ながい", romaji: "nagai" },
        { text: "みじかい", romaji: "mijikai" }, { text: "あつい", romaji: "atsui" }, { text: "さむい", romaji: "samui" }, { text: "あたたかい", romaji: "atatakai" }, { text: "すずしい", romaji: "suzushii" },
        { text: "あたらしい", romaji: "atarashii" }, { text: "ふるい", romaji: "furui" }, { text: "いい", romaji: "ii" }, { text: "わるい", romaji: "warui" }, { text: "はやい", romaji: "hayai" },
        { text: "おそい", romaji: "osoi" }, { text: "むずかしい", romaji: "muzukashii" }, { text: "やさしい", romaji: "yasashii" }, { text: "おもしろい", romaji: "omoshiroi" }, { text: "つまらない", romaji: "tsumaranai" },
        { text: "ありがとう", romaji: "arigatou" }, { text: "ごめんなさい", romaji: "gomennasai" }, { text: "さようなら", romaji: "sayounara" }, { text: "はじめまして", romaji: "hajimemashite" }, { text: "おつかれさま", romaji: "otsukaresama" },
        { text: "かぞく", romaji: "kazoku" }, { text: "ともだち", romaji: "tomodachi" }, { text: "せんせい", romaji: "sensei" }, { text: "せいと", romaji: "seito" }, { text: "こども", romaji: "kodomo" },
        { text: "おとな", romaji: "otona" }, { text: "おとこ", romaji: "otoko" }, { text: "おんな", romaji: "onna" }, { text: "みらい", romaji: "mirai" }, { text: "かこ", romaji: "kako" }
    ];

    let shuffledWords = [];
    let currentWordIndex = 0;
    let currentCharIndex = 0;
    let isPlaying = false;

    const wordDisplay = document.getElementById('word-display');
    const romajiDisplay = document.getElementById('romaji-display');
    const messageDisplay = document.getElementById('message');
    const progressDisplay = document.getElementById('progress');

    // 配列をランダムにシャッフルする関数
    function shuffleArray(array) {
        for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
        }
        return array;
    }

    // ゲーム開始時の設定
    function startGame() {
        isPlaying = true;
        messageDisplay.textContent = "";
        currentWordIndex = 0;
        
        // 元の配列をコピーしてシャッフル
        shuffledWords = shuffleArray([...words]); 
        setNextWord();
    }

    // 問題をセットする関数
    function setNextWord() {
        if (currentWordIndex >= shuffledWords.length) {
            wordDisplay.textContent = "全クリア！";
            romajiDisplay.innerHTML = "";
            progressDisplay.textContent = `${shuffledWords.length} / ${shuffledWords.length}`;
            messageDisplay.textContent = "素晴らしい！スペースキーで再挑戦できます。";
            isPlaying = false;
            return;
        }

        progressDisplay.textContent = `${currentWordIndex + 1} / ${shuffledWords.length}`;
        const currentWord = shuffledWords[currentWordIndex];
        wordDisplay.textContent = currentWord.text;
        currentCharIndex = 0;
        updateRomajiDisplay();
    }

    // ローマ字の表示を更新する関数
    function updateRomajiDisplay() {
        const currentWord = shuffledWords[currentWordIndex];
        const typedPart = currentWord.romaji.substring(0, currentCharIndex);
        const untypedPart = currentWord.romaji.substring(currentCharIndex);
        
        romajiDisplay.innerHTML = `<span class="typed">${typedPart}</span><span class="untyped">${untypedPart}</span>`;
    }

    // キー入力イベントの処理
    document.addEventListener('keydown', (e) => {
        // スペースキーなどのデフォルト動作を防ぐ
        if(e.key === " ") e.preventDefault();

        // プレイ中でない場合はスタート（またはリスタート）
        if (!isPlaying) {
            startGame();
            return;
        }

        const currentWord = shuffledWords[currentWordIndex];
        
        // 入力されたキーが正解か判定
        if (e.key === currentWord.romaji[currentCharIndex]) {
            currentCharIndex++;
            updateRomajiDisplay();

            // 最後まで打ち終えたら次の単語へ
            if (currentCharIndex === currentWord.romaji.length) {
                currentWordIndex++;
                setTimeout(setNextWord, 150); // 少しだけ待ってから次の問題へ
            }
        }
    });

    // 初期表示
    progressDisplay.textContent = `0 / ${words.length}`;
    wordDisplay.textContent = "スペースキーで開始";
    romajiDisplay.textContent = "space";
</script>

</body>
</html>
