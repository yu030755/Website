        { text: "すし", romaji: "sushi" }, { text: "らーめん", romaji: "ra-men" }, { text: "うどん", romaji: "udon" }, { text: "そば", romaji: "soba" }, { text: "てんぷら", romaji: "tenpura" },
        { text: "かれー", romaji: "kare-" }, { text: "ぴざ", romaji: "piza" }, { text: "ぱん", romaji: "pan" }, { text: "おにぎり", romaji: "onigiri" }, { text: "さらだ", romaji: "sarada" },
        { text: "ぎゅうにく", romaji: "gyuuniku" }, { text: "ぶたにく", romaji: "butaniku" }, { text: "とりにく", romaji: "toriniku" }, { text: "たまご", romaji: "tamago" }, { text: "ちーず", romaji: "chi-zu" },
